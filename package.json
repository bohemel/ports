{
  "name": "ports",
  "version": "0.1.0",
  "description": "A Bun-powered CLI managed with pnpm.",
  "type": "module",
  "bin": {
    "ports": "./src/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile ./dist/ports",
    "test": "bun test"
  },
  "keywords": [
    "bun",
    "cli",
    "pnpm"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "bun": ">=1.3.11",
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0"
  }
}
